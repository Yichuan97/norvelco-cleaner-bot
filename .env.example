# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
# Your phone number ID (already set as default)
WHATSAPP_PHONE_NUMBER_ID=1114153555115533

# Paste your permanent System User access token here
# Get it from: Meta Business Settings → System Users → Norvelco Bot → Generate token
WHATSAPP_ACCESS_TOKEN=your_permanent_token_here

# Random string for webhook verification (you choose this)
WEBHOOK_VERIFY_TOKEN=norvelco_verify_2024

# ─── Guesty API ───────────────────────────────────────────────────────────────
# Get from: Guesty Dashboard → Integrations → API
GUESTY_API_KEY=your_guesty_api_key_here

# ─── Schedule (24-hour format) ────────────────────────────────────────────────
DAILY_TASK_HOUR=8
DAILY_TASK_MINUTE=0
REVIEW_CHECK_HOUR=7
REVIEW_CHECK_MINUTE=30
CELEBRATE_HOUR=18
CELEBRATE_MINUTE=0
TIMEZONE=America/New_York

# ─── Photo Requirements ───────────────────────────────────────────────────────
REQUIRED_PHOTOS_PER_TASK=10
